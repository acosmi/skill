        "video_info",
        "channel_info",
        "comments"
      ],
      "description": "search=搜索视频, video_info=视频详情, channel_info=频道信息, comments=评论"
    },
    "query": {
      "type": "string",
      "description": "搜索关键词（search 时使用）"
    },
    "video_id": {
      "type": "string",
      "description": "视频 ID（video_info/comments 时使用）"
