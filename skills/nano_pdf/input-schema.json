{
  "type": "object",
  "properties": {
    "input": {
      "type": "string",
      "description": "输入 PDF 文件路径"
    },
    "instruction": {
      "type": "string",
      "description": "自然语言编辑指令（如“删除第2页”“在页脚加页码”“合并这两个PDF”）"
    },
    "output": {
      "type": "string",
      "description": "输出文件路径，默认覆盖或新建"
    },
    "pages": {
      "type": "string",
      "description": "目标页范围（如 1-3,5），可选"
    }
  },
  "required": [
    "input",
    "instruction"
  ]
}
