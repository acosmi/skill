{
  "type": "object",
  "properties": {
    "query": {
      "type": "string",
      "description": "查询内容或搜索关键词"
    },
    "url": {
      "type": "string",
      "description": "目标 URL 地址"
    },
    "file_path": {
      "type": "string",
      "description": "文件路径"
    },
    "repository": {
      "type": "string",
      "description": "仓库标识 (owner/repo)"
    },
    "action": {
      "type": "string",
      "enum": [
        "read",
        "send",
        "search",
        "list"
      ]
    },
    "command": {
      "type": "string",
      "description": "要执行的 CLI 命令"
    },
    "env_vars": {
      "type": "object",
      "description": "所需环境变量: GA4_PROPERTY_ID, GA4_PRIVATE_KEY, SEARCH_CONSOLE_SITE_URL"
    }
  },
  "required": [
    "query"
  ]
}
