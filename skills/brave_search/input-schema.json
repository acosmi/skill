{
  "type": "object",
  "properties": {
    "query": {
      "type": "string",
      "description": "搜索关键词"
    },
    "count": {
      "type": "integer",
      "description": "返回结果数量，默认 10，最大 20"
    },
    "freshness": {
      "type": "string",
      "enum": [
        "pd",
        "pw",
        "pm",
        "py"
      ],
      "description": "时间过滤：pd=24h, pw=一周, pm=一月, py=一年"
    },
    "country": {
      "type": "string",
      "description": "国家代码过滤（如 CN/US/JP）"
    },
    "search_lang": {
      "type": "string",
      "description": "搜索语言（如 zh-hans/en）"
    }
  },
  "required": [
    "query"
  ]
}
